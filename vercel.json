{
  "version": 2,
  "builds": [
    { "src": "index.html",           "use": "@vercel/static" },
    { "src": "LsbuTour.html",        "use": "@vercel/static" },
    { "src": "css/**",               "use": "@vercel/static" },
    { "src": "js/**",                "use": "@vercel/static" },
    { "src": "lib/**",               "use": "@vercel/static" },
    { "src": "assets/images/**",     "use": "@vercel/static" },
    { "src": "assets/anims/**",      "use": "@vercel/static" },
    { "src": "assets/audio/**",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",                    "dest": "/index.html"        },
    { "src": "/LsbuTour",            "dest": "/LsbuTour.html"     },
    { "src": "/LsbuTour.html",       "dest": "/LsbuTour.html"     },
    { "src": "/css/(.*)",            "dest": "/css/$1"            },
    { "src": "/js/(.*)",             "dest": "/js/$1"             },
    { "src": "/lib/(.*)",            "dest": "/lib/$1"            },
    { "src": "/assets/images/(.*)",  "dest": "/assets/images/$1"  },
    { "src": "/assets/anims/(.*)",   "dest": "/assets/anims/$1"   },
    { "src": "/assets/audio/(.*)",   "dest": "/assets/audio/$1"   }
  ]
}