{
  "builds": [
    { "src": "app.py", "use": "@vercel/python" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "lib/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/lib/(.*)", "dest": "/lib/$1" },
    { "src": "/(.*)", "dest": "app.py" }
  ]
}